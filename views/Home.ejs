<!-- ====== CTA BANNER ====== -->
<section class="cta-banner">
    <div class="cta-content">
        <h2>Ready to Find Your <span class="text-gold">Perfect Bag?</span></h2>
        <p>Browse our full collection of premium bags for every style and occasion.</p>
        <a href="/products" class="btn-gold btn-lg">
            <i class="fas fa-shopping-bag"></i> Shop the Collection
        </a>
