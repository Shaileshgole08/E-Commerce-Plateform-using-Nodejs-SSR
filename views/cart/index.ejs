<% layout('layout/boilerplate') %>

<div class="page-header">
    <div class="container">
        <h1 class="page-title"><i class="fas fa-shopping-cart"></i> My Cart</h1>
        <div class="breadcrumb">
            <a href="/">Home</a> <i class="fas fa-chevron-right"></i> <span>Cart</span>
        </div>
    </div>
</div>

<div class="container">
    <% if (!cartItems || cartItems.length === 0) { %>
        <div class="empty-state cart-empty">
            <i class="fas fa-shopping-cart empty-icon"></i>
            <h3>Your cart is empty</h3>
            <p>Looks like you haven't added anything yet. Start shopping!</p>
            <a href="/products" class="btn-gold mt-3">
                <i class="fas fa-shopping-bag"></i> Browse Products
            </a>
        </div>
    <% } else { %>
        <div class="cart-layout">
            <!-- Cart Items -->
            <div class="cart-items-section">
                <div class="cart-items-header">
                    <span>Product</span>
                    <span>Price</span>
                    <span>Quantity</span>
                    <span>Subtotal</span>
                    <span></span>
                </div>

                <% cartItems.forEach(item => { %>
                    <div class="cart-item animate-fade-in-up">
                        <div class="cart-item-product">
                            <img src="<%= item.product.images[0] || '/images/bag-placeholder.svg' %>" 
                                 alt="<%= item.product.name %>" class="cart-item-img">
                            <div class="cart-item-details">
                                <a href="/products/<%= item.product._id %>" class="cart-item-name">
                                    <%= item.product.name %>
                                </a>
                                <span class="cart-item-cat"><%= item.product.category %></span>
                                <% if (item.product.stock < 5 && item.product.stock > 0) { %>
                                    <span class="stock-low">Only <%= item.product.stock %> left!</span>
                                <% } %>
                            </div>
                        </div>
                        <div class="cart-item-price">₹<%= item.product.price.toLocaleString('en-IN') %></div>
                        <div class="cart-item-qty">
                            <form action="/cart/<%= item.product._id %>?_method=PATCH" method="POST" class="qty-form">
                                <div class="qty-control">
                                    <button type="button" onclick="adjustCartQty(this, -1)">−</button>
                                    <input type="number" name="quantity" value="<%= item.quantity %>" 
                                           min="1" max="<%= item.product.stock %>"
                                           class="qty-input" onchange="this.form.submit()">
                                    <button type="button" onclick="adjustCartQty(this, 1)">+</button>
                                </div>
                            </form>
                        </div>
                        <div class="cart-item-subtotal">
                            ₹<%= (item.product.price * item.quantity).toLocaleString('en-IN') %>
                        </div>
                        <form action="/cart/<%= item.product._id %>?_method=DELETE" method="POST">
                            <button type="submit" class="cart-remove-btn" 
                                    onclick="return confirm('Remove this item from cart?')">
                                <i class="fas fa-trash-alt"></i>
                            </button>
                        </form>
                    </div>
                <% }) %>

                <div class="cart-actions">
                    <a href="/products" class="btn-outline-gold">
                        <i class="fas fa-arrow-left"></i> Continue Shopping
                    </a>
                </div>
            </div>

            <!-- Order Summary -->
            <div class="cart-summary">
                <h3><i class="fas fa-receipt"></i> Order Summary</h3>
                <div class="summary-row">
                    <span>Subtotal (<%= cartItems.length %> items)</span>
                    <span>₹<%= subtotal.toLocaleString('en-IN') %></span>
                </div>
                <div class="summary-row">
                    <span>Shipping</span>
                    <span class="<%= shipping === 0 ? 'text-success' : '' %>">
                        <%= shipping === 0 ? 'FREE' : '₹' + shipping %>
                    </span>
                </div>
                <% if (shipping > 0) { %>
                    <div class="free-shipping-hint">
                        Add ₹<%= (999 - subtotal).toLocaleString('en-IN') %> more for FREE shipping!
                    </div>
                <% } %>
                <div class="summary-divider"></div>
                <div class="summary-row summary-total">
                    <span>Total</span>
                    <span>₹<%= total.toLocaleString('en-IN') %></span>
                </div>
                <a href="/orders/checkout" class="btn-gold btn-full mt-3">
                    <i class="fas fa-lock"></i> Proceed to Checkout
                </a>
                <div class="summary-security">
                    <i class="fas fa-shield-alt"></i> Secure & Encrypted Checkout
                </div>
            </div>
        </div>
    <% } %>
</div>

<script>
function adjustCartQty(btn, delta) {
    const form = btn.closest('form');
    const input = form.querySelector('.qty-input');
    let val = parseInt(input.value) + delta;
    val = Math.max(1, Math.min(val, parseInt(input.max)));
    input.value = val;
    form.submit();
}
</script>
