<% layout('layout/boilerplate') %>

<div class="auth-page">
    <div class="auth-visual">
        <div class="auth-visual-content">
            <i class="fas fa-shopping-bag auth-big-icon"></i>
            <h2>Welcome Back!</h2>
            <p>Sign in to access your cart, wishlist, and order history.</p>
            <div class="auth-features">
                <div><i class="fas fa-check-circle"></i> Track your orders</div>
                <div><i class="fas fa-check-circle"></i> Save to wishlist</div>
                <div><i class="fas fa-check-circle"></i> Fast checkout</div>
            </div>
        </div>
    </div>
    
    <div class="auth-form-section">
        <div class="auth-form-wrap">
            <div class="auth-header">
                <a href="/" class="auth-logo"><img src="/images/logo.png" alt="Raju Bag House" class="auth-logo-img"></a>
                <h1>Sign In</h1>
                <p>Don't have an account? <a href="/auth/register" class="auth-link">Register here</a></p>
            </div>

            <form action="/auth/login" method="POST" class="auth-form" id="loginForm">
                <div class="form-group">
                    <label for="email">Email Address</label>
                    <div class="input-wrap">
                        <i class="fas fa-envelope input-icon"></i>
                        <input type="email" id="email" name="email" class="form-input" 
                               placeholder="your@email.com" required autocomplete="email">
                    </div>
                </div>
                
                <div class="form-group">
                    <label for="password">Password</label>
                    <div class="input-wrap">
                        <i class="fas fa-lock input-icon"></i>
                        <input type="password" id="password" name="password" class="form-input" 
                               placeholder="Enter your password" required autocomplete="current-password">
                        <button type="button" class="toggle-password" onclick="togglePassword('password')">
                            <i class="fas fa-eye" id="toggleIcon-password"></i>
                        </button>
                    </div>
                </div>

                <button type="submit" class="btn-gold btn-full" id="loginBtn">
                    <span>Sign In</span>
                    <i class="fas fa-sign-in-alt"></i>
                </button>
            </form>

            <div class="auth-divider"><span>or</span></div>
            
            <div class="auth-admin-hint">
                <i class="fas fa-shield-alt"></i>
                <span>Admin? Use your admin credentials to access the dashboard.</span>
            </div>
        </div>
    </div>
</div>

<script>
function togglePassword(id) {
    const input = document.getElementById(id);
    const icon = document.getElementById('toggleIcon-' + id);
    if (input.type === 'password') {
        input.type = 'text';
        icon.classList.replace('fa-eye', 'fa-eye-slash');
    } else {
        input.type = 'password';
        icon.classList.replace('fa-eye-slash', 'fa-eye');
    }
}
</script>
